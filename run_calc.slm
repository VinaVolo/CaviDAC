#!/bin/bash
#SBATCH --job-name=ddp_test
#SBATCH --output=ddp_%j.out
#SBATCH --error=ddp_%j.err
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=20
#SBATCH --gpus-per-node=0
#SBATCH --time=24:00:00
#SBATCH --export=ALL

cd $SLURM_SUBMIT_DIR

# Заранее синхронизировали окружение (разовый шаг)
uv sync --locked  # если используете uv

source .venv/bin/activate

srun python RUN_CALCULATION.py